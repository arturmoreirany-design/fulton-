// ═══════════════════════════════════════════════════════════════
function UnitMarker({ unit, floor, status, selected, onClick }) {
const filled  = status === “installed”;
const dotColor = {
installed:”#15803D”, missing:”#DC2626”, delivered:”#B45309”,
staged:”#0E7490”, punch:”#7C3AED”,
}[status] || “#9A9888”;

return (
<g
transform={`translate(${unit.x},${unit.y})`}
onClick={() => onClick(unit.id)}
onKeyDown={e => { if (e.key === “Enter” || e.key === “ “) onClick(unit.id); }}
role=“button”
aria-label={`Unit ${unit.id} — ${STATUSES[status]?.label || "Pending"}`}
tabIndex={0}
style={{ cursor:“pointer”, outline:“none” }}
>
{selected && (
<circle r="21" fill="none" stroke={floor.color} strokeWidth="2.5" opacity="0.45">
<animate attributeName="r" values="19;24;19" dur="2s" repeatCount="indefinite"/>
<animate attributeName="opacity" values="0.45;0.1;0.45" dur="2s" repeatCount="indefinite"/>
</circle>
)}
<rect
x=”-24” y=”-16” width=“48” height=“32” rx=“8”
fill={filled ? floor.color : selected ? floor.color : floor.light}
stroke={floor.color}
strokeWidth={selected||filled ? 0 : status===“missing” ? 2.2 : 1.8}
strokeDasharray={status===“missing” ? “3,2” : “none”}
opacity=“0.97”
/>
<text textAnchor=“middle” y=“6” fontSize=“12”
fontFamily=“Plus Jakarta Sans, system-ui” fontWeight=“800”
letterSpacing=”-0.3”
fill={filled||selected ? “white” : floor.dark}>
{unit.id}
</text>
<circle cx="20" cy="-13" r="5.5" fill={dotColor} stroke="white" strokeWidth="1.5"/>
</g>
);
}

